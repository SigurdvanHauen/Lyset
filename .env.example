# Copy this file to .env and fill in your details.
# .env is gitignored and never committed.
#
# All of these can also be edited from the web UI: click the ⚙ Settings button
# (top-right). Saving writes back to this .env and live-restarts the affected
# workers — no manual editing or restart required.

# ── Inverter (Modbus TCP over the SDongle) ────────────────────────────────────
# LAN address of the inverter's SDongle. Find it in your router's client list.
# INVERTER_HOST=192.168.1.185
# INVERTER_PORT=502
# INVERTER_SLAVE_ID=1
# INVERTER_POLL_INTERVAL=10

# ── Electricity prices (Strømligning API) ─────────────────────────────────────
# Get a free API key at https://stromligning.dk/artikler/elpris-api

STROMLIGNING_API_KEY=your_stromligning_api_key_here

# Danish postal code — used to auto-detect your DSO and tariffs.
# STROMLIGNING_POSTAL_CODE=5500

# Override DSO auto-lookup (optional — only needed if the postal code maps to
# multiple DSOs and you want to pick a specific one).
# Find your supplier ID at: https://stromligning.dk/api/suppliers/find?postalCode=5500
# STROMLIGNING_SUPPLIER_ID=trefor_el-net_c

# Feed-in/balance tariffs (DKK/kWh) subtracted from the spot price to get your
# export price. Matches Vindstød's surplus settlement. Default: 0.033375.
# PRICE_EXPORT_FEE=0.033375

# Seconds between price refreshes (default 1800 / 30 min).
# PRICE_POLL_INTERVAL=1800

# ── Solcast solar forecast ─────────────────────────────────────────────────────
# Get a free API key at https://toolkit.solcast.com.au/register/hobbyist
# Free Hobbyist plan: 10 API calls/day. Default poll interval is 6 h (safe for 2 sites).

SOLCAST_API_KEY=your_solcast_api_key_here

# Rooftop site resource UUID(s) — visible in Solcast Toolkit after registering sites.
# Comma-separate multiple sites; their forecasts are summed (e.g. south + west panels).
# Leave blank to auto-discover all sites (uses 1 daily API call on startup).
# SOLCAST_RESOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx,yyyyyyyy-yyyy-yyyy-yyyy

# Hours of day (local time) to fetch forecasts. Default: 06:00, 12:00, 18:00.
# 3 fetches/day × 2 sites = 6 API calls/day (free tier: 10).
# Restarting the server does NOT trigger an immediate fetch.
# SOLCAST_FETCH_HOURS=6,12,18

# Seconds between Solcast refresh cycles (default 21600 = 6 h).
# SOLCAST_POLL_INTERVAL=21600

# ── Consumption prediction ─────────────────────────────────────────────────────
# Path to a MeterData.xlsx file (from your grid operator) to seed the model.
# Only read once — when no model file (lyset_model.json) exists yet.
# After seeding, the model updates automatically from live Modbus data.
# CONSUMPTION_HISTORY_PATH=C:/Users/YourName/Downloads/MeterData.xlsx

# ── Auto controller ────────────────────────────────────────────────────────────
# Start the battery auto-controller when the server launches (1) or leave it
# off until you enable it from the UI (0). Default: 1.
# AUTO_CONTROLLER_AUTOSTART=1

# FusionSolar credentials — copy this file to .env and fill in your details.
# .env is gitignored and never committed.
#
# Use your regular FusionSolar login (the same credentials you use on
# fusionsolar.huawei.com or in the FusionSolar app).

FUSIONSOLAR_USER=your_fusionsolar_email@example.com
FUSIONSOLAR_PASS=your_fusionsolar_password

# Subdomain — the first part of the URL when you log into FusionSolar.
# eu5.fusionsolar.huawei.com → eu5 (default)
# intl.fusionsolar.huawei.com → intl
# FUSIONSOLAR_SUBDOMAIN=eu5

# Optional: poll interval in seconds (default 120).
# FUSIONSOLAR_POLL_INTERVAL=120

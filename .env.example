# Copy this file to .env and fill in your details.
# .env is gitignored and never committed.

# ── Electricity prices (Strømligning API) ─────────────────────────────────────
# Get a free API key at https://stromligning.dk/artikler/elpris-api

STROMLIGNING_API_KEY=your_stromligning_api_key_here

# Danish postal code — used to auto-detect your DSO and tariffs.
# STROMLIGNING_POSTAL_CODE=5500

# Override DSO auto-lookup (optional — only needed if the postal code maps to
# multiple DSOs and you want to pick a specific one).
# Find your supplier ID at: https://stromligning.dk/api/suppliers/find?postalCode=5500
# STROMLIGNING_SUPPLIER_ID=trefor_el-net_c

# Elafgift (electricity tax) DKK/kWh excl. VAT — used only to estimate the
# export/spot price by subtracting it from the electricity cost component.
# 2025 standard residential rate: 0.763. Adjust if you have a reduced rate.
# PRICE_ELAFGIFT=0.763

# Seconds between price refreshes (default 1800 / 30 min).
# PRICE_POLL_INTERVAL=1800

# ── Solcast solar forecast ─────────────────────────────────────────────────────
# Get a free API key at https://toolkit.solcast.com.au/register/hobbyist
# Free Hobbyist plan: 10 API calls/day. Default poll interval is 6 h (safe for 2 sites).

SOLCAST_API_KEY=your_solcast_api_key_here

# Rooftop site resource UUID(s) — visible in Solcast Toolkit after registering sites.
# Comma-separate multiple sites; their forecasts are summed (e.g. south + west panels).
# Leave blank to auto-discover all sites (uses 1 daily API call on startup).
# SOLCAST_RESOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx,yyyyyyyy-yyyy-yyyy-yyyy

# Seconds between forecast refreshes (default 21600 = 6 h).
# SOLCAST_POLL_INTERVAL=21600
